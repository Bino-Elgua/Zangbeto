### Phase 4: Zangbeto Enforcement & Agent Integration (Week 3)

#### 4.1 Update `zbt_core.move` — Diagnostic Receipt Lifecycle
```move
// shrine/sources/zbt_core.move (append new functions)

use zbt::diagnostics::{Self as diag, DiagnosticReceipt};

/// Submit a canonical diagnostic receipt (replaces generic submit_receipt for diagnostics)
public fun submit_diagnostic_receipt(
    ws: &WitnessSet,
    rl: &mut ReceiptLedger,  // legacy ledger for backwards compat
    diag_ledger: &mut DiagnosticLedger,  // new typed ledger
    clock_ref: &Clock,
    witness: &signer,
    payload: diag::ZangbetoPayload,  // validated struct from helper
): ID {
    // 1. Validate payload schema (double-check)
    assert!(diag::validate_schema(
        &payload.code, payload.severity, payload.category, 
        &payload.message_hash, &payload.agent_id
    ), E_SCHEMA_INVALID);

    // 2. Create and emit diagnostic receipt
    let receipt = diag::emit_diagnostic(
        ctx,  // from witness context
        payload.code, payload.severity, payload.category,
        payload.message_hash, payload.agent_id,
        payload.birth_epoch, payload.tier, payload.sabbath_active,
        payload.repair_id, payload.repair_strategy,
        &GUARDIAN_PUBKEY,  // module constant
    );
    
    // 3. Emit event for agent consumption
    guard::emit_diagnostic_event(&receipt, ctx);
    
    // 4. Store in typed ledger for efficient querying
    let receipt_id = object::uid_to_inner(&receipt.id);
    table::add(&mut diag_ledger.table, receipt_id, receipt);
    
    // 5. Also store in legacy ReceiptLedger for backwards compat (optional)
    // let legacy_id = submit_receipt(...);  // if needed
    
    receipt_id
}

/// Query diagnostics by agent + category (for agent repair loop)
public fun query_diagnostics_by_agent(
    diag_ledger: &DiagnosticLedger,
    agent_id: vector<u8>,
    category: u8,
    limit: u64,
): vector<DiagnosticReceipt> {
    let results = vector::empty();
    let mut count = 0;
    let ids = table::keys(&diag_ledger.table);
    let mut i = 0;
    
    while (i < vector::length(&ids) && count < limit) {
        let id = *vector::borrow(&ids, i);
        let receipt = table::borrow(&diag_ledger.table, id);
        if (receipt.agent_id == agent_id && receipt.category == category) {
            vector::push_back(&mut results, *receipt);
            count = count + 1;
        };
        i = i + 1;
    };
    results
}
```

#### 4.2 Agent Diagnostic Handler (Rust Steward Core)
```rust
// omokoda-core/src/agent/diagnostic_handler.rs (enhanced)
use omo_diagnostic::{Diagnostic, ZangbetoClient};
use zangbeto_ipc::ZangbetoResponse;

pub struct DiagnosticHandler {
    zangbeto: ZangbetoClient,
    repair_registry: HashMap<String, Box<dyn RepairStrategy>>,
    receipt_store: Arc<Mutex<ReceiptStore>>,
}

impl DiagnosticHandler {
    /// Main entry: called when stderr line matches canonical diagnostic JSON
    pub async fn handle_diagnostic(&mut self, diag: Diagnostic) -> HandlerResult {
        // 1. Log to immutable local receipt store
        self.receipt_store.lock().await.log(&diag);
        
        // 2. If repair plan exists and strategy=auto, attempt local repair first
        if let Some(plan) = &diag.repair {
            if plan.strategy == "auto" {
                if let Some(strategy) = self.repair_registry.get(&plan.id) {
                    match strategy.execute(&plan.steps).await {
                        Ok(result) => {
                            // Success: emit FixEvent to Zangbeto
                            self.zangbeto.emit_fix_event(&diag, &result).await?;
                            return Ok(HandlerAction::Repaired(result));
                        }
                        Err(e) => {
                            // Failure: escalate to Zangbeto for on-chain tracking
                            warn!("Auto-repair failed for {}: {:?}", plan.id, e);
                        }
                    }
                }
            }
        }
        
        // 3. Forward to Zangbeto for on-chain emission + anchoring
        let submission = self.zangbeto.submit_diagnostic(&diag).await?;
        
        // 4. If security/identity category, block further execution until verified
        if matches!(diag.diagnostic.category, Category::Security | Category::Identity) {
            // Wait for Zangbeto verification webhook or poll for status
            let verified = self.wait_for_verification(&submission.receipt_id).await?;
            if !verified {
                return Err(HandlerError::UnverifiedCriticalDiagnostic);
            }
        }
        
        // 5. Return action for steward: retry, pause, or escalate
        Ok(HandlerAction::ForwardedToZangbeto(submission))
    }
    
    /// Poll Zangbeto for verification status (with timeout)
    async fn wait_for_verification(&self, receipt_id: &str) -> Result<bool, Error> {
        let timeout = Duration::from_secs(300);  // 5 min max
        let start = Instant::now();
        
        while start.elapsed() < timeout {
            let status = self.zangbeto.get_receipt_status(receipt_id).await?;
            match status.as_str() {
                "verified" | "fixed" => return Ok(true),
                "disputed" | "risk_accepted" => return Ok(false),
                "pending" => tokio::time::sleep(Duration::from_secs(5)).await,
                _ => return Err(Error::UnknownStatus(status)),
            }
        }
        Err(Error::VerificationTimeout)
    }
}
```

