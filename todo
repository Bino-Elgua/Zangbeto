## ⚒️ Implementation Plan: Embed Structured Diagnostics into Zàngbétò

### Phase 1: Canonical Schema Definition (Week 1)

#### 1.1 Create `zbt_diagnostics.move` — Schema Enforcement Module
```move
// shrine/sources/zbt_diagnostics.move
module zbt::diagnostics {
    use std::string;
    use std::vector;
    use 0x2::object::{Self, UID};
    use 0x2::tx_context::{Self, TxContext};
    use 0x2::bcs;
    use 0x2::hash::blake2b256;
    use zbt::errors::E_SCHEMA_INVALID;

    /// Canonical diagnostic code format: OMO-ERR-XXX
    const CODE_PREFIX: vector<u8> = b"OMO-ERR-";
    const MAX_CODE_LEN: u64 = 16;
    const SHA256_LEN: u64 = 32;

    /// Severity levels (mirrors omo-diagnostic crate)
    const SEV_INFO: u8 = 0;
    const SEV_WARNING: u8 = 1;
    const SEV_ERROR: u8 = 2;

    /// Category bitfield (type|logic|security|receipt|identity|rhythm)
    const CAT_TYPE: u8 = 1;
    const CAT_LOGIC: u8 = 2;
    const CAT_SECURITY: u8 = 4;
    const CAT_RECEIPT: u8 = 8;
    const CAT_IDENTITY: u8 = 16;
    const CAT_RHYTHM: u8 = 32;

    /// Structured diagnostic receipt — emitted when any language violates a rule
    struct DiagnosticReceipt has key, store {
        id: UID,
        // Core diagnostic fields
        code: vector<u8>,           // "OMO-ERR-042"
        severity: u8,               // 0|1|2
        category: u8,               // bitfield
        message_hash: vector<u8>,   // SHA-256 of human message (privacy)
        // Context for agent reasoning
        agent_id: vector<u8>,       // 0x... agent address
        birth_epoch: u64,           // identity-critical timestamp
        tier: u8,                   // apprentice=1|adept=2|master=3
        sabbath_active: bool,       // Rhythm gate
        // Repair plan reference
        repair_id: vector<u8>,      // e.g., b"fix-tier-gate"
        repair_strategy: u8,        // auto=1|manual=2|hybrid=3
        // Immutable audit trail
        zangbeto_sig: vector<u8>,   // Ed25519 sig of hash(code||message_hash||agent_id)
        arweave_tx: option<vector<u8>>,
        ots_proof: option<vector<u8>>,
        submitted_at: u64,          // epoch seconds
    }

    /// Validate diagnostic conforms to canonical schema
    public fun validate_schema(
        code: &vector<u8>,
        severity: u8,
        category: u8,
        message_hash: &vector<u8>,
        agent_id: &vector<u8>,
    ): bool {
        // 1. Code starts with prefix and is within length
        if (!vector::starts_with(code, &CODE_PREFIX)) { return false };
        if (vector::length(code) > MAX_CODE_LEN) { return false };
        // 2. Severity in valid range
        if (severity > SEV_ERROR) { return false };
        // 3. Category is valid bitfield (single bit or known combo)
        let valid_cats = vector::vector[CAT_TYPE, CAT_LOGIC, CAT_SECURITY, CAT_RECEIPT, CAT_IDENTITY, CAT_RHYTHM];
        if (!vector::contains(&valid_cats, &category) && category != 0) { return false };
        // 4. Message hash is SHA-256 length
        if (vector::length(message_hash) != SHA256_LEN) { return false };
        // 5. Agent ID is valid address length (32 bytes for Sui)
        if (vector::length(agent_id) != 32) { return false };
        true
    }

    /// Emit a validated diagnostic receipt — called by any module detecting violation
    public fun emit_diagnostic(
        ctx: &mut TxContext,
        code: vector<u8>,
        severity: u8,
        category: u8,
        message_hash: vector<u8>,
        agent_id: vector<u8>,
        birth_epoch: u64,
        tier: u8,
        sabbath_active: bool,
        repair_id: vector<u8>,
        repair_strategy: u8,
        guardian_key: &vector<u8>,  // Ed25519 public key of Zangbeto guardian
    ): DiagnosticReceipt {
        // Validate before emission
        assert!(validate_schema(&code, severity, category, &message_hash, &agent_id), E_SCHEMA_INVALID);

        // Compute signature payload: hash(code || message_hash || agent_id)
        let mut sig_payload = vector::empty<u8>();
        sig_payload = vector::append(&sig_payload, &code);
        sig_payload = vector::append(&sig_payload, &message_hash);
        sig_payload = vector::append(&sig_payload, &agent_id);
        let digest = blake2b256(&sig_payload);
        
        // In production: sign with guardian private key in secure enclave
        // For devnet: use deterministic mock signature
        let mock_sig = vector::slice(&digest, 0, 64);  // placeholder

        DiagnosticReceipt {
            id: object::new(ctx),
            code,
            severity,
            category,
            message_hash,
            agent_id,
            birth_epoch,
            tier,
            sabbath_active,
            repair_id,
            repair_strategy,
            zangbeto_sig: mock_sig,
            arweave_tx: option::none(),
            ots_proof: option::none(),
            submitted_at: tx_context::epoch(ctx),
        }
    }

    /// Anchor diagnostic to Arweave + OpenTimestamps (off-chain helper calls this)
    public fun anchor_receipt(
        receipt: &mut DiagnosticReceipt,
        arweave_tx: vector<u8>,
        ots_proof: vector<u8>,
    ) {
        receipt.arweave_tx = option::some(arweave_tx);
        receipt.ots_proof = option::some(ots_proof);
    }

    /// Verify signature (called by agent before trusting repair plan)
    public fun verify_signature(
        receipt: &DiagnosticReceipt,
        guardian_pubkey: &vector<u8>,
    ): bool {
        // In production: use 0x2::crypto::ed25519_verify
        // For now: placeholder that always returns true in devnet
        true
    }

    /// Get human-readable category name (for debugging/logging)
    public fun category_name(cat: u8): vector<u8> {
        if (cat == CAT_TYPE) { b"type" }
        else if (cat == CAT_LOGIC) { b"logic" }
        else if (cat == CAT_SECURITY) { b"security" }
        else if (cat == CAT_RECEIPT) { b"receipt" }
        else if (cat == CAT_IDENTITY) { b"identity" }
        else if (cat == CAT_RHYTHM) { b"rhythm" }
        else { b"unknown" }
    }
}
```

