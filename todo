├── Move.toml              # Sui Move package config (v0.1.8)
├── package.json           # Node deps: @mysten/sui.js, arweave, dotenv
├── Makefile               # patrol/anchor/shrine-bootstrap targets
├── README.md              # Ritual-driven red-team protocol docs
├── .env.example           # SUI_NETWORK, ARWEAVE_KEY, etc.
├── shrine/
│   ├── sources/
│   │   ├── zbt_errors.move    # Error codes (E_NOT_WITNESS=9101, etc.)
│   │   ├── zbt_guard.move     # Event emission: InvariantBreach, ReceiptEvent, FixEvent
│   │   └── zbt_core.move      # ReceiptLedger, WitnessSet, lifecycle functions
