// shrine/sources/zbt_guard.move (append)
use zbt::diagnostics::DiagnosticReceipt;

/// Emitted when a canonical diagnostic is validated and emitted
struct DiagnosticEmitted has drop, store {
    receipt_id: ID,
    code: vector<u8>,
    severity: u8,
    category: u8,
    agent_id: vector<u8>,
    repair_id: vector<u8>,
}

/// Emitted when agent executes auto-repair (for audit trail)
struct AutoRepairExecuted has drop, store {
    receipt_id: ID,
    repair_id: vector<u8>,
    result: bool,  // success/failure
    gas_used: u64,
}

public fun emit_diagnostic_event(receipt: &DiagnosticReceipt, ctx: &mut TxContext) {
    event::emit(DiagnosticEmitted {
        receipt_id: object::uid_to_inner(&receipt.id),
        code: receipt.code,
        severity: receipt.severity,
        category: receipt.category,
        agent_id: receipt.agent_id,
        repair_id: receipt.repair_id,
    });
}
