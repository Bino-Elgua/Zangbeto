```rust
// crates/omo-diagnostic/src/lib.rs
use serde::{Serialize, Deserialize};
use schemars::JsonSchema;

#[derive(Serialize, Deserialize, JsonSchema, Debug, Clone)]
#[serde(rename_all = "snake_case")]
pub enum Severity { Info, Warning, Error }

#[derive(Serialize, Deserialize, JsonSchema, Debug, Clone)]
#[serde(rename_all = "snake_case")]
pub enum Category { Type, Logic, Security, Receipt, Identity, Rhythm }

#[derive(Serialize, Deserialize, JsonSchema, Debug, Clone)]
pub struct Diagnostic {
    pub version: String,  // "1.0"
    pub source: SourceLocation,
    pub diagnostic: DiagnosticInfo,
    #[serde(skip_serializing_if = "Option::is_none")]
    pub repair: Option<RepairPlan>,
    pub audit_trail: AuditTrail,
}

// ... (full structs as previously defined)

/// Helper: Convert Rust Diagnostic → Move-compatible payload for Zangbeto
pub fn to_zangbeto_payload(&self) -> ZangbetoPayload {
    ZangbetoPayload {
        code: self.diagnostic.code.clone(),
        severity: match self.diagnostic.severity {
            Severity::Info => 0,
            Severity::Warning => 1,
            Severity::Error => 2,
        },
        category: self.diagnostic.category as u8,  // bitfield mapping
        message_hash: sha2_256(self.diagnostic.message.as_bytes()).to_vec(),
        agent_id: self.diagnostic.context.agent_id.clone().unwrap_or_default(),
        birth_epoch: self.diagnostic.context.birth_timestamp.unwrap_or(0),
        tier: match self.diagnostic.context.tier.as_deref() {
            Some("apprentice") => 1,
            Some("adept") => 2,
            Some("master") => 3,
            _ => 0,
        },
        sabbath_active: self.diagnostic.context.sabbath_active,
        repair_id: self.repair.as_ref().map(|r| r.id.clone()).unwrap_or_default(),
        repair_strategy: match self.repair.as_ref().and_then(|r| r.strategy.as_deref()) {
            Some("auto") => 1,
            Some("manual") => 2,
            Some("hybrid") => 3,
            _ => 2,  // default to manual
        },
    }
}
```

#### 2.2 Add Zangbeto IPC Client
```rust
// crates/omo-diagnostic/src/zangbeto_client.rs
use reqwest::Client;
use serde_json::json;

pub struct ZangbetoClient {
    http: Client,
    endpoint: String,
    guardian_pubkey: String,
}

impl ZangbetoClient {
    pub fn new(endpoint: String, guardian_pubkey: String) -> Self {
        Self {
            http: Client::new(),
            endpoint,
            guardian_pubkey,
        }
    }

    /// Submit diagnostic to Zangbeto for on-chain emission + anchoring
    pub async fn submit_diagnostic(&self, diag: &Diagnostic) -> Result<SubmissionResponse, Error> {
        let payload = diag.to_zangbeto_payload();
        
        let response = self.http
            .post(&format!("{}/diagnostics", self.endpoint))
            .header("X-Guardian-Pubkey", &self.guardian_pubkey)
            .json(&payload)
            .send()
            .await?
            .json::<SubmissionResponse>()
            .await?;
        
        // Verify Zangbeto signature before trusting
        if !verify_zangbeto_sig(&response, &self.guardian_pubkey)? {
            return Err(Error::SignatureInvalid);
        }
        
        Ok(response)
    }
}
```

