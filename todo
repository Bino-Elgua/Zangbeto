#### 5.2 Add `scripts/test_zangbeto_submit.rs`
```rust
// scripts/test_zangbeto_submit.rs
use omo_diagnostic::{Diagnostic, SourceLocation, DiagnosticInfo, DiagnosticContext, Severity, Category, RepairPlan, RepairStep, RepairValidation, AuditTrail};
use omo_diagnostic::zangbeto_client::ZangbetoClient;

#[tokio::main]
async fn main() -> Result<(), Box<dyn std::error::Error>> {
    let args = std::env::args().collect::<Vec<_>>();
    let endpoint = args.iter().position(|a| a == "--endpoint").and_then(|i| args.get(i+1)).expect("missing --endpoint");
    let guardian_pubkey = args.iter().position(|a| a == "--guardian-pubkey").and_then(|i| args.get(i+1)).expect("missing --guardian-pubkey");
    
    let client = ZangbetoClient::new(endpoint.clone(), guardian_pubkey.clone());
    
    // Create test diagnostic: overflow in payments.move
    let diag = Diagnostic {
        version: "1.0".into(),
        source: SourceLocation {
            language: "move".into(),
            package: "zangbeto-example".into(),
            file: "examples/payments.move".into(),
            line: 27,
            column: 12,
            span: None,
        },
        diagnostic: DiagnosticInfo {
            code: "OMO-ERR-023".into(),
            severity: Severity::Error,
            category: Category::Logic,
            message: "Balance underflow in payment transfer".into(),
            context: DiagnosticContext {
                agent_id: Some("0xabc123...".into()),
                birth_timestamp: Some(1716234567),
                tier: Some("apprentice".into()),
                sabbath_active: false,
            },
        },
        repair: Some(RepairPlan {
            id: "fix-balance-check".into(),
            strategy: "auto".into(),
            steps: vec![RepairStep {
                action: "insert".into(),
                target: "code".into(),
                payload: serde_json::json!({"check": "balance >= amount", "before": "transfer"}),
            }],
            validation: RepairValidation {
                pre_check: "sui move test --filter payments".into(),
                post_check: "receipt_chain_verify".into(),
                rollback_safe: true,
            },
        }),
        audit_trail: AuditTrail {
            zangbeto_verified: false,
            arweave_anchor: None,
            ots_proof: None,
            timestamp: chrono::Utc::now().to_rfc3339(),
        },
    };
    
    println!("Submitting diagnostic to Zangbeto...");
    let response = client.submit_diagnostic(&diag).await?;
    println!("✅ Submitted: receipt_id={}", response.receipt_id);
    println!("🔗 Arweave: {:?}", response.arweave_tx);
    println!("⏱️  OTS: {:?}", response.ots_proof);
    
    Ok(())
}
```

